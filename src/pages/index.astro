---
import { getCollection } from 'astro:content';
import { formatDate } from '../utils';

// リンクハブ：各ドキュメントの最新版へ誘導する。
async function latest(kind: 'terms' | 'privacy') {
  const entries = (await getCollection(kind)).sort(
    (a, b) => b.data.version - a.data.version,
  );
  return entries.find((e) => e.data.status === 'current') ?? entries[0];
}

const docs = [
  { kind: 'terms' as const, entry: await latest('terms') },
  { kind: 'privacy' as const, entry: await latest('privacy') },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>UnplaQuest 法務情報</title>
    <link rel="canonical" href={new URL('/', Astro.site)} />
  </head>
  <body>
    <main>
      <header>
        <h1>UnplaQuest 法務情報</h1>
        <p class="lead">利用規約とプライバシーポリシーの最新版・過去版を掲載しています。</p>
      </header>

      <ul class="doc-list">
        {
          docs.map(({ kind, entry }) => (
            <li>
              <a class="card" href={`/${kind}`}>
                <span class="card-title">{entry.data.title}</span>
                <span class="card-meta">
                  最新：第{entry.data.version}版 ・ 効力発生日：
                  {formatDate(entry.data.effectiveDate)}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>

<style is:global>
  :root {
    --bg: #ffffff;
    --text: #1a1a1a;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --accent: #2563eb;
    --card-hover: #f9fafb;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0f1115;
      --text: #e8e8ea;
      --text-muted: #9aa0a6;
      --border: #2a2d34;
      --accent: #6ea8fe;
      --card-hover: #171a20;
    }
  }
  * {
    box-sizing: border-box;
  }
  html {
    color-scheme: light dark;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP',
      'Helvetica Neue', Arial, sans-serif;
    line-height: 1.7;
  }
  main {
    max-width: 40rem;
    margin: 0 auto;
    padding: 4rem 1.25rem;
  }
  h1 {
    font-size: 1.9rem;
    margin: 0 0 0.5rem;
  }
  .lead {
    color: var(--text-muted);
    margin: 0 0 2.5rem;
  }
  .doc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.15s ease;
  }
  .card:hover {
    background: var(--card-hover);
  }
  .card-title {
    font-size: 1.15rem;
    font-weight: 600;
  }
  .card-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
